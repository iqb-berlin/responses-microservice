{
  "name": "responses-microservice",
  "version": "0.1.0",
  "description": "REST API microservice wrapper for @iqb/responses.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/iqb-berlin/responses-microservice.git"
  },
  "bugs": {
    "url": "https://github.com/iqb-berlin/responses-microservice/issues"
  },
  "homepage": "https://github.com/iqb-berlin/responses-microservice#readme",
  "main": "dist/server.js",
  "scripts": {
    "build": "tsc",
    "check": "npm run lint && npm test && npm run build && npm audit --omit=dev",
    "lint": "eslint .",
    "load-test:schemes-code": "./scripts/load-tests/run-responses-schemes-code.sh",
    "start": "node dist/server.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=22"
  },
  "dependencies": {
    "@iqb/responses": "^5.2.0",
    "@iqbspecs/coding-scheme": "^3.3.1",
    "@iqbspecs/response": "^2.0.0",
    "@iqbspecs/variable-info": "^1.3.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "express-rate-limit": "^8.5.2"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^26.1.0",
    "@types/supertest": "^7.2.0",
    "eslint": "^10.6.0",
    "supertest": "^7.2.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.62.1",
    "vitest": "^4.1.10"
  }
}
